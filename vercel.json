{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://www.dahandev.site https://dahandev.site;"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/guia-destrave",
      "destination": "/guia-destrave/index.html"
    },
    {
      "source": "/sorteio",
      "destination": "/sorteio/index.html"
    },
    {
      "source": "/nina-admin",
      "destination": "/admin/index.html"
    }
  ]
}
